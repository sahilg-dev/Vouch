# Your OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1/responses

# Optional: Adzuna job search API credentials
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Local Postgres from docker-compose.yml
DATABASE_URL=Host=localhost;Port=5432;Database=jobcopilot;Username=jobcopilot;Password=jobcopilot
FRONTEND_ORIGIN=http://localhost:5173
